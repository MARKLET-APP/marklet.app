# ─── API Server (.env in artifacts/api-server/) ──────────────────────────────
NODE_ENV=production
PORT=8080

# PostgreSQL — Neon, Supabase, Render Postgres, etc.
DATABASE_URL=postgresql://user:password@host:5432/marklet

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=change-me-to-a-long-random-secret

# Firebase FCM (paste the full service account JSON as one line)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
FCM_SERVER_KEY=AAAA...

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BNJ...
VAPID_PRIVATE_KEY=xXx...

# OpenAI (optional — for AI price estimator & description generator)
OPENAI_API_KEY=sk-...

# CORS: URL of the deployed frontend (Vercel)
FRONTEND_URL=https://marklet.app

# ─── Frontend (.env in artifacts/syrian-car-market/) ─────────────────────────
# URL of the deployed backend (Render)
VITE_API_URL=https://marklet-api.onrender.com
